{
  "name": "@visorcraft/mongreldb",
  "version": "0.19.0",
  "description": "High-performance Node.js bindings for MongrelDB with native in-process storage, sub-ms writes, and hybrid indexing.",
  "main": "index.js",
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/visorcraft/MongrelDB.git",
    "directory": "crates/mongreldb-node"
  },
  "napi": {
    "name": "mongreldb",
    "package": {
      "name": "@visorcraft/mongreldb-native"
    }
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --release --platform --strip --js native.js --dts native.d.ts",
    "build:debug": "napi build --platform --js native.js --dts native.d.ts",
    "test": "node --test"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "native.js",
    "native.d.ts",
    "smoke.mjs",
    "mongreldb.*.node"
  ],
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "engines": {
    "node": ">= 16"
  }
}
