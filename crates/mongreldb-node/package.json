{
  "name": "mongreldb",
  "version": "0.17.0",
  "description": "Native Node.js addon for MongrelDB — in-process, sub-ms writes, hybrid index queries.",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "mongreldb",
    "package": {
      "name": "@mongreldb/native"
    }
  },
  "scripts": {
    "build": "napi build --release --platform --js native.js --dts native.d.ts",
    "build:debug": "napi build --platform --js native.js --dts native.d.ts",
    "prepare": "npm run build",
    "test": "node --test"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "native.js",
    "native.d.ts",
    "smoke.mjs",
    "mongreldb.*.node"
  ],
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "engines": {
    "node": ">= 16"
  }
}
